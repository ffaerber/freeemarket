{
  "name": "@freemarket/schema",
  "version": "0.1.0",
  "description": "Shared Swarm JSON schema (TS types + runtime validation) for FreeMarket clients.",
  "license": "MIT",
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "src",
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "tsx --test test/*.test.ts"
  },
  "dependencies": {
    "ajv": "^8.20.0"
  },
  "devDependencies": {
    "tsx": "^4.22.3",
    "typescript": "^5.9.3"
  }
}

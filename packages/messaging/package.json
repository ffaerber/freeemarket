{
  "name": "@freemarket/messaging",
  "version": "0.1.0",
  "description": "Bidirectional encrypted messaging over Swarm PSS for FreeeMarket: ECIES + signed envelopes with on-chain sender verification (buyer→seller shipping address, seller→buyer tracking code).",
  "license": "MIT",
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "src",
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "tsx --test test/*.test.ts"
  },
  "dependencies": {
    "@ethersphere/bee-js": "^8.3.1",
    "eciesjs": "^0.4.11",
    "viem": "^2.21.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.22.3",
    "typescript": "^5.9.3"
  }
}

# FreeMarket Storefront — environment configuration.
#
# Copy to `.env` and fill in for a REAL shop. When VITE_MARKETPLACE_ADDRESS and
# VITE_SELLER are BOTH unset, the app runs in DEMO MODE (renders a sample shop
# from the ported template config) so the build/preview shows something.
#
# Only VITE_-prefixed vars are exposed to the client by Vite. Never put secrets
# (private keys, postage-batch IDs, etc.) here — this is a public static app.

# Address of the shared Marketplace escrow contract on Gnosis Chain (id 100).
VITE_MARKETPLACE_ADDRESS=

# This shop's seller address. Listings are filtered to those created by this
# address (the contract is shared across all shops; the storefront is per-shop).
VITE_SELLER=

# Gnosis Chain JSON-RPC endpoint. Default below is the public Gnosis RPC.
VITE_RPC_URL=https://rpc.gnosischain.com

# Swarm Bee/gateway base URL. Used to download shop + listing metadata JSON and
# to resolve image references. Defaults to the public Swarm gateway. For real
# deployments (and to use PSS), point this at your own Bee node, e.g.
# http://localhost:1633.
VITE_BEE_URL=https://api.gateway.ethswarm.org

# Optional: override the shop profile metadata Swarm reference. Normally the app
# reads `shops(seller).metadata` on-chain; set this to short-circuit that read
# (useful before the shop is registered, or for previewing a profile).
VITE_SHOP_METADATA=

# SwarmChat ContactRegistry contract address. Resolves the SELLER's published
# ECIES public key on-chain so the buyer can encrypt their shipping address to it
# (CLAUDE.md §5). When UNSET (or the lookup returns no key) the encrypted-address
# flow is unconfigured and the checkout falls back to the existing stub (escrow
# still works). NOTE: confirm the registry's exact ABI/selector against the
# deployed SwarmChat registry — it's centralized in src/lib/contactRegistry.js.
VITE_CONTACT_REGISTRY=

# Postage batch ID ("stamp") for the BUYER's own Bee node — REQUIRED to actually
# send the encrypted address over Swarm PSS. The buyer needs a writeable FULL Bee
# node (VITE_BEE_URL) + this batch; both-parties-need-a-node is the main PSS UX
# friction (CLAUDE.md §5). NOT a secret, but per-node. When unset, address
# delivery stays stubbed and the checkout shows the "PSS delivery pending" note.
VITE_POSTAGE_BATCH_ID=
